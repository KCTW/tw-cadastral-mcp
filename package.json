{
  "name": "tw-cadastral-mcp",
  "version": "0.1.0",
  "description": "MCP server for querying Taiwan cadastral (land registry) data from easymap.land.moi.gov.tw",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tw-cadastral-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "taiwan",
    "cadastral",
    "land-registry",
    "easymap"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
